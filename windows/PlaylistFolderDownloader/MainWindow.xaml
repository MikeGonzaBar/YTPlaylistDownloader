<Window
    x:Class="PlaylistFolderDownloader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PlaylistFolderDownloader"
    Title="Playlist Folder Downloader">
    <Grid
        x:Name="Root"
        Padding="16,14,16,14"
        Background="#18000000"
        RequestedTheme="Dark"
        RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="124" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="Playlist or video URL" />
            <TextBox
                x:Name="UrlBox"
                Grid.Column="1"
                MinWidth="420"
                PlaceholderText="https://www.youtube.com/playlist?list=..." />
            <Button
                Grid.Column="2"
                Click="LoadClicked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Refresh" />
                    <TextBlock Text="Load" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="3"
                Click="SettingsClicked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Setting" />
                    <TextBlock Text="Settings" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="4"
                Click="AboutClicked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Help" />
                    <TextBlock Text="About" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="MessageText"
                Text="{Binding Message, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                x:Name="ProbeStatusText"
                Grid.Column="1"
                Text="Loading per-video options"
                Visibility="Collapsed" />
            <TextBlock
                x:Name="VideoCountText"
                Grid.Column="2"
                Text="0 videos" />
            <TextBlock
                Grid.Column="3"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Native WinUI 3 frontend" />
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border
                Background="#66202020"
                BorderBrush="#35FFFFFF"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid
                        Padding="8,7"
                        Background="#33FFFFFF"
                        ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="72" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="138" />
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="92" />
                            <ColumnDefinition Width="96" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Selected" TextAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Index" TextAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Title" />
                        <TextBlock Grid.Column="3" Text="Duration" TextAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="Channel" />
                        <TextBlock Grid.Column="5" Text="Status" TextAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="Quality" TextAlignment="Center" />
                        <TextBlock Grid.Column="7" Text="Audio" TextAlignment="Center" />
                    </Grid>

                    <ListView
                        x:Name="VideosList"
                        Grid.Row="1"
                        ItemsSource="{Binding Videos}"
                        SelectionChanged="VideosListSelectionChanged"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:VideoInfo">
                                <Grid
                                    MinHeight="36"
                                    Padding="8,0"
                                    ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="138" />
                                        <ColumnDefinition Width="112" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="{Binding IndexText}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Text="{Binding Title}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="{Binding DurationText}" />
                                    <TextBlock
                                        Grid.Column="4"
                                        VerticalAlignment="Center"
                                        Text="{Binding Channel}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="{Binding Status}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="{Binding QualitySummary}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="7"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="{Binding AudioSummary}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Background="#66202020"
                BorderBrush="#35FFFFFF"
                BorderThickness="1"
                CornerRadius="8">
                <ScrollViewer Padding="14">
                    <StackPanel Spacing="11">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Video Options" />
                        <TextBlock
                            x:Name="FocusedTitleText"
                            MaxLines="2"
                            Text="Select a video to edit options."
                            TextTrimming="CharacterEllipsis" />

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox
                                x:Name="IncludeVideoBox"
                                Checked="OptionControlChanged"
                                Content="Include video"
                                Unchecked="OptionControlChanged" />
                            <CheckBox
                                x:Name="IncludeAudioBox"
                                Grid.Column="1"
                                Checked="OptionControlChanged"
                                Content="Include audio"
                                Unchecked="OptionControlChanged" />
                        </Grid>

                        <TextBlock FontWeight="SemiBold" Text="Quality" />
                        <ComboBox
                            x:Name="QualityCombo"
                            MinWidth="220"
                            SelectionChanged="QualitySelectionChanged" />

                        <TextBlock FontWeight="SemiBold" Text="Video formats" />
                        <ListView
                            x:Name="VideoFormatsList"
                            MaxHeight="76"
                            SelectionChanged="VideoFormatsSelectionChanged"
                            SelectionMode="Single" />

                        <TextBlock FontWeight="SemiBold" Text="Audio tracks" />
                        <StackPanel x:Name="AudioTracksPanel" Spacing="4" />

                        <Button Click="ProbeClicked">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Find" />
                                <TextBlock Text="Probe formats" />
                            </StackPanel>
                        </Button>

                        <CheckBox
                            x:Name="SubtitlesEnabledBox"
                            Checked="OptionControlChanged"
                            Content="Subtitles"
                            Unchecked="OptionControlChanged" />
                        <CheckBox
                            x:Name="ManualSubtitlesBox"
                            Checked="OptionControlChanged"
                            Content="Manual subtitles"
                            Unchecked="OptionControlChanged" />
                        <CheckBox
                            x:Name="AutoSubtitlesBox"
                            Checked="OptionControlChanged"
                            Content="Auto subtitles"
                            Unchecked="OptionControlChanged" />

                        <TextBlock FontWeight="SemiBold" Text="Subtitle languages" />
                        <StackPanel x:Name="SubtitleLanguagesPanel" Spacing="4" />

                        <CheckBox
                            x:Name="EmbedSubtitlesBox"
                            Checked="OptionControlChanged"
                            Content="Embed subtitles"
                            Unchecked="OptionControlChanged" />
                        <CheckBox
                            x:Name="KeepSubtitleFilesBox"
                            Checked="OptionControlChanged"
                            Content="Keep subtitle files"
                            Unchecked="OptionControlChanged" />

                        <TextBlock FontWeight="SemiBold" Text="Container" />
                        <ComboBox
                            x:Name="ContainerCombo"
                            MinWidth="140"
                            SelectionChanged="OptionSelectionChanged">
                            <ComboBoxItem Content="mkv" />
                            <ComboBoxItem Content="mp4" />
                            <ComboBoxItem Content="webm" />
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border
            Grid.Row="3"
            Background="#66202020"
            BorderBrush="#35FFFFFF"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Download Queue" />
                <ListView
                    x:Name="QueueList"
                    Grid.Row="1"
                    ItemsSource="{Binding Queue}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:QueueItem">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{Binding DisplayText}"
                                    TextTrimming="CharacterEllipsis" />
                                <ProgressBar
                                    Grid.Column="1"
                                    Maximum="100"
                                    Value="{Binding Percent, Mode=OneWay}" />
                                <Button
                                    Grid.Column="2"
                                    Click="RemoveQueueItemClicked"
                                    Tag="{Binding Id}">
                                    <SymbolIcon Symbol="Cancel" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Row="4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Click="SelectAllClicked" Content="Select all" />
            <Button
                Grid.Column="1"
                Click="DeselectAllClicked"
                Content="Deselect all" />
            <Button
                Grid.Column="3"
                Click="ApplySelectedClicked"
                Content="Apply to selected" />
            <Button
                Grid.Column="4"
                Click="ApplyAllClicked"
                Content="Apply to all" />
            <Button
                x:Name="DownloadButton"
                Grid.Column="5"
                Click="DownloadSelectedClicked">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Download" />
                    <TextBlock Text="Download selected" />
                </StackPanel>
            </Button>
            <Button
                x:Name="CancelButton"
                Grid.Column="6"
                Click="CancelClicked"
                Content="Cancel"
                IsEnabled="False" />
        </Grid>
    </Grid>
</Window>
